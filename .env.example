# =========================================
# SkyWay Flight Booking - Environment Config
# =========================================
# Copy this file to .env and replace with your actual API keys.
# NEVER commit this file to version control.

# ── API Keys ─────────────────────────────────

# Skyscanner API (via RapidAPI)
# Sign up: https://rapidapi.com/skyscanner/api/skyscanner-flight-search
SKYSCANNER_API_KEY=YOUR_SKYSCANNER_API_KEY

# Amadeus API
# Sign up: https://developers.amadeus.com/
AMADEUS_API_KEY=YOUR_AMADEUS_API_KEY
AMADEUS_API_SECRET=YOUR_AMADEUS_API_SECRET

# AviationStack API
# Sign up: https://aviationstack.com/
AVIATIONSTACK_API_KEY=YOUR_AVIATIONSTACK_API_KEY

# ── API Endpoints ────────────────────────────
SKYSCANNER_API_URL=https://skyscanner-api.p.rapidapi.com/v3/flights/live/search/create
AMADEUS_API_URL=https://test.api.amadeus.com/v2/shopping/flight-offers
AVIATIONSTACK_API_URL=http://api.aviationstack.com/v1

# ── App Configuration ────────────────────────
PORT=3000
DEFAULT_CURRENCY=INR
DEFAULT_MARKET=IN
DEFAULT_LOCALE=en-IN
MAX_RESULTS=50
